<Window x:Class="TheGrandNotch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TheGrandNotch.Converters"
        xmlns:anim="clr-namespace:TheGrandNotch.Animation"
        Title="TheGrandNotch"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        SizeToContent="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Window.Resources>
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />

        <!-- Boutons Accepter / Refuser pour les transferts entrants -->
        <Style x:Key="AcceptButton" TargetType="Button">
            <Setter Property="Background" Value="#2866AA44" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#DDFFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusL}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="8,5" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4066CC44" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#5566CC44" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DeclineButton" TargetType="Button">
            <Setter Property="Background" Value="#28AA4444" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#DDFFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusL}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="8,5" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#40CC4444" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#55CC4444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MediaButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF" />
                                <!-- Bouton bondissant repris de TheBoringNotch : pressé 0.9,
                                     relâché avec ressort marqué (spring response 0.3, damping 0.3) -->
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="bd"
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                To="0.9" Duration="0:0:0.10">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="bd"
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                To="0.9" Duration="0:0:0.10">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="bd"
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                To="1" Duration="0:0:0.34">
                                                <DoubleAnimation.EasingFunction>
                                                    <anim:SpringEase Damping="0.45" Stiffness="12" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="bd"
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                To="1" Duration="0:0:0.34">
                                                <DoubleAnimation.EasingFunction>
                                                    <anim:SpringEase Damping="0.45" Stiffness="12" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{x:Null}">
        <!-- Halo ambiant : forme colorée floutée placée DERRIÈRE la notch, déborde en douceur -->
        <Border x:Name="GlowLayer"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Width="220"
                Height="36"
                CornerRadius="18"
                Opacity="0"
                IsHitTestVisible="False">
            <Border.Background>
                <SolidColorBrush x:Name="GlowBrush" Color="#FF000000" />
            </Border.Background>
            <Border.Effect>
                <BlurEffect x:Name="GlowBlur" Radius="55" KernelType="Gaussian" />
            </Border.Effect>
        </Border>

        <Border x:Name="NotchBorder"
                Background="#FF000000"
                CornerRadius="0,0,18,18"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Width="220"
                Height="36"
                ClipToBounds="True"
                AllowDrop="True"
                MouseEnter="OnNotchMouseEnter"
                MouseLeave="OnNotchMouseLeave"
                DragEnter="OnNotchDragEnter"
                DragOver="OnNotchDragEnter"
                DragLeave="OnNotchDragLeave"
                Drop="OnNotchDrop">

            <!-- Slide-in depuis le dessus au démarrage ; Y=-60 = hors-écran -->
            <Border.RenderTransform>
                <TranslateTransform x:Name="NotchSlideT" Y="-60" />
            </Border.RenderTransform>

          <Grid>
            <!-- Ronds flous animés façon lampe à lave, masque de fondu pour ne pas allumer les coins -->
            <Grid x:Name="InnerGlow" Opacity="0" IsHitTestVisible="False">
                <Grid.OpacityMask>
                    <!-- Masque radial : s'estompe dans toutes les directions, atteint 0 avant les bords -->
                    <RadialGradientBrush Center="0.36,0.5" GradientOrigin="0.36,0.5"
                                         RadiusX="0.36" RadiusY="0.40">
                        <GradientStop Offset="0" Color="#FF000000" />
                        <GradientStop Offset="0.42" Color="#FF000000" />
                        <GradientStop Offset="0.82" Color="#00000000" />
                        <GradientStop Offset="1" Color="#00000000" />
                    </RadialGradientBrush>
                </Grid.OpacityMask>
                <Grid>
                    <Grid.Effect>
                        <BlurEffect Radius="46" KernelType="Gaussian" />
                    </Grid.Effect>
                    <Canvas>
                        <Ellipse x:Name="Blob1" Width="160" Height="160" Canvas.Left="30" Canvas.Top="15">
                            <Ellipse.Fill><SolidColorBrush x:Name="Blob1Brush" /></Ellipse.Fill>
                            <Ellipse.RenderTransform><TranslateTransform x:Name="Blob1T" /></Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse x:Name="Blob2" Width="160" Height="160" Canvas.Left="216" Canvas.Top="5">
                            <Ellipse.Fill><SolidColorBrush x:Name="Blob2Brush" /></Ellipse.Fill>
                            <Ellipse.RenderTransform><TranslateTransform x:Name="Blob2T" /></Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse x:Name="Blob3" Width="160" Height="160" Canvas.Left="400" Canvas.Top="20">
                            <Ellipse.Fill><SolidColorBrush x:Name="Blob3Brush" /></Ellipse.Fill>
                            <Ellipse.RenderTransform><TranslateTransform x:Name="Blob3T" /></Ellipse.RenderTransform>
                        </Ellipse>
                    </Canvas>
                </Grid>
            </Grid>

            <Grid x:Name="MediaContent" Opacity="0" IsHitTestVisible="False" Margin="18,8,18,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ===== BARRE DU HAUT : onglets (gauche) + système (droite) ===== -->
                <Grid Grid.Row="0" Margin="2,0,2,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Style="{StaticResource MediaButton}" ToolTip="Accueil" Click="OnHomeTabClick">
                            <Path x:Name="HomeIcon" Fill="White" Stretch="Uniform" Width="17" Height="17"
                                  Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
                        </Button>
                        <Button Style="{StaticResource MediaButton}" ToolTip="Réseau" Click="OnNetworkTabClick" Margin="2,0,0,0">
                            <Grid Width="20" Height="20">
                                <Path x:Name="NetworkIcon" Fill="#99FFFFFF" Stretch="Uniform" Width="17" Height="17"
                                      Data="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z" />
                                <!-- Badge : nombre de fichiers en attente d'envoi -->
                                <Border x:Name="NetworkBadge" Width="11" Height="11" CornerRadius="5.5"
                                        Background="#FF0A84FF"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-4,-4,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="NetworkBadgeText" Text="0"
                                               Foreground="White" FontSize="{StaticResource FontMicro}" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Button>
                        <!-- Onglet sortie audio -->
                        <Button Style="{StaticResource MediaButton}" ToolTip="Sortie audio" Click="OnAudioTabClick" Margin="2,0,0,0">
                            <Path x:Name="AudioIcon" Fill="#99FFFFFF" Stretch="Uniform" Width="17" Height="17"
                                  Data="M12 1c-4.97 0-9 4.03-9 9v7c0 1.1.9 2 2 2h1v-8H5v-1c0-3.87 3.13-7 7-7s7 3.13 7 7v1h-1v8h2c1.1 0 2-.9 2-2v-7c0-4.97-4.03-9-9-9z" />
                        </Button>
                        <!-- Onglet calendrier -->
                        <Button Style="{StaticResource MediaButton}" ToolTip="Calendrier" Click="OnCalendarTabClick" Margin="2,0,0,0">
                            <Path x:Name="CalendarIcon" Fill="#99FFFFFF" Stretch="Uniform" Width="17" Height="17"
                                  Data="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7v-5z" />
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="CoffeeButton" Style="{StaticResource MediaButton}"
                                ToolTip="Keep-Awake — maintient l'écran actif"
                                Click="OnCoffeeToggleClick" Margin="0,0,2,0">
                            <Path x:Name="CoffeeIcon" Fill="White" Opacity="0.60" Stretch="Uniform" Width="16" Height="16"
                                  RenderTransformOrigin="0.5,0.5"
                                  Data="M20 3H4v10c0 2.21 1.79 4 4 4h6c2.21 0 4-1.79 4-4v-3h2c1.1 0 2-.89 2-2V5c0-1.11-.89-2-2-2zm0 5h-2V5h2v3zM4 19h16v2H4z">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="CoffeeIconScale" ScaleX="1" ScaleY="1" />
                                </Path.RenderTransform>
                            </Path>
                        </Button>
                        <Button Style="{StaticResource MediaButton}" ToolTip="Paramètres"
                                Click="OnSettingsTabClick"
                                MouseEnter="OnSettingsHover" MouseLeave="OnSettingsLeave">
                            <Path Fill="#CCFFFFFF" Stretch="Uniform" Width="16" Height="16"
                                  RenderTransformOrigin="0.5,0.5"
                                  Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="GearRotate" />
                                </Path.RenderTransform>
                            </Path>
                        </Button>
                        <TextBlock x:Name="BatteryText" Text="--%"
                                   Foreground="White" FontSize="{StaticResource FontBody}" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="4,0,6,0" />
                        <Grid VerticalAlignment="Center" Width="29" Height="14">
                            <Border Width="26" Height="13" CornerRadius="3.5"
                                    BorderBrush="#CCFFFFFF" BorderThickness="1.3"
                                    HorizontalAlignment="Left" VerticalAlignment="Center" />
                            <Border x:Name="BatteryFill" Width="22" Height="10" CornerRadius="1.5"
                                    Background="#FF34C759"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="2.5,0,0,0" />
                            <Border Width="2.5" Height="5" CornerRadius="1.5"
                                    Background="#CCFFFFFF"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="26.5,0,0,0" />
                            <Path x:Name="BatteryBolt" Fill="Black" Stretch="Uniform"
                                  Width="6" Height="10" Visibility="Collapsed"
                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                  Margin="10,0,0,0"
                                  Data="M6,0 L0,7 H4 L3,14 L10,5 H5 Z" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- ===== PAGE ACCUEIL : pochette | média | calendrier ===== -->
                <Grid x:Name="HomeView" Grid.Row="1">
                    <Grid.RenderTransform><TranslateTransform x:Name="HomeViewT" /></Grid.RenderTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Pochette -->
                    <Grid Grid.Column="0" VerticalAlignment="Center" Width="84" Height="84">
                        <Border CornerRadius="{StaticResource Radius2XL}" Background="#22FFFFFF" />
                        <Image Source="{Binding AlbumArt}" Stretch="Uniform">
                            <Image.Clip>
                                <RectangleGeometry Rect="0,0,84,84" RadiusX="12" RadiusY="12" />
                            </Image.Clip>
                        </Image>
                        <Border Width="26" Height="26" CornerRadius="13"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,-6,-6" Background="#FF000000"
                                Visibility="{Binding SourceAppIcon, Converter={StaticResource NullToCollapsed}}">
                            <Image Source="{Binding SourceAppIcon}" Width="22" Height="22">
                                <Image.Clip>
                                    <EllipseGeometry Center="11,11" RadiusX="11" RadiusY="11" />
                                </Image.Clip>
                            </Image>
                        </Border>
                    </Grid>

                    <!-- Média : titre / artiste / barre / temps / contrôles -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="18,0,18,0">
                        <TextBlock Text="{Binding Title, FallbackValue='Aucun média', TargetNullValue='Aucun média'}"
                                   Foreground="White" FontSize="{StaticResource FontTitle}" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Artist, TargetNullValue=''}"
                                   Foreground="#B3FFFFFF" FontSize="{StaticResource FontBody}"
                                   TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                                   Margin="0,1,0,0" />

                        <Grid x:Name="ProgressBarContainer" Height="16" Margin="0,8,0,0">
                            <!-- Les deux barres : 3px, centrées, épaissies via ScaleY pendant le scrub -->
                            <Grid Height="3" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="ProgressBarsScale" ScaleY="1" />
                                </Grid.RenderTransform>
                                <Border Background="#33FFFFFF" CornerRadius="1.5" />
                                <Border x:Name="ProgressBarFill"
                                        Background="White" CornerRadius="1.5"
                                        HorizontalAlignment="Left" Width="0" />
                            </Grid>
                            <Ellipse x:Name="ScrubThumb" Width="12" Height="12"
                                     Fill="#FFD0D0D0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Opacity="0" IsHitTestVisible="False" />
                            <Border Background="Transparent" Cursor="Hand"
                                    MouseLeftButtonDown="OnProgressBarMouseDown"
                                    MouseMove="OnProgressBarMouseMove"
                                    MouseLeftButtonUp="OnProgressBarMouseUp" />
                        </Grid>

                        <Grid Margin="0,2,0,0">
                            <TextBlock Text="{Binding PositionText}" Foreground="#99FFFFFF" FontSize="{StaticResource FontCaption2}" HorizontalAlignment="Left" />
                            <TextBlock Text="{Binding DurationText}" Foreground="#99FFFFFF" FontSize="{StaticResource FontCaption2}" HorizontalAlignment="Right" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                            <Button Style="{StaticResource MediaButton}" ToolTip="Précédent"
                                    IsEnabled="{Binding HasSession}" Click="OnPreviousClick">
                                <Path Fill="White" Stretch="None" Data="M0,0 H3.5 V14 H0 Z M12,0 V14 L4,7 Z" />
                            </Button>
                            <Button Style="{StaticResource MediaButton}" ToolTip="Lecture / Pause"
                                    IsEnabled="{Binding HasSession}" Click="OnPlayPauseClick" Margin="8,0">
                                <Grid>
                                    <Path x:Name="PlayGlyph" Fill="White" Stretch="None"
                                          Data="M0,0 L11,7 L0,14 Z"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <TransformGroup>
                                                <!-- Centrage optique : un triangle vers la droite a sa masse visuelle à gauche → +1px -->
                                                <TranslateTransform X="1" />
                                                <ScaleTransform x:Name="PlayGlyphScale" ScaleX="1" ScaleY="1" />
                                            </TransformGroup>
                                        </Path.RenderTransform>
                                    </Path>
                                    <Path x:Name="PauseGlyph" Fill="White" Stretch="None"
                                          Data="M0,0 H3.5 V14 H0 Z M6.5,0 H10 V14 H6.5 Z"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Opacity="0" RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <ScaleTransform x:Name="PauseGlyphScale" ScaleX="0.6" ScaleY="0.6" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource MediaButton}" ToolTip="Suivant"
                                    IsEnabled="{Binding HasSession}" Click="OnNextClick">
                                <Path Fill="White" Stretch="None" Data="M0,0 L8,7 L0,14 Z M8.5,0 H12 V14 H8.5 Z" />
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Mini calendrier minimaliste — clic ouvre l'onglet complet -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Width="148"
                                Cursor="Hand" Background="Transparent"
                                ToolTip="Ouvrir le calendrier"
                                MouseLeftButtonUp="OnMiniCalendarClick">

                        <!-- Date du jour : numéro + jour · mois -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#20FFFFFF" VerticalAlignment="Center" Margin="0,0,9,0">
                                <TextBlock x:Name="CalMiniNum" Text="—"
                                           FontSize="{StaticResource FontBody}" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="CalMiniWeekday" Text="—"
                                           FontSize="{StaticResource FontCaption2}" FontWeight="SemiBold"
                                           Foreground="#CCffffff"/>
                                <TextBlock x:Name="CalMiniMonthYear" Text="—"
                                           FontSize="{StaticResource FontMicro}"
                                           Foreground="#55FFFFFF" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Prochains événements (max 2, alimenté par code) -->
                        <StackPanel x:Name="CalMiniEventList" />

                    </StackPanel>
                </Grid>

                <!-- ===== PAGE PARTAGE : Boîte (gauche) + Envoi LocalSend (droite) ===== -->
                <Grid x:Name="NetworkView" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RenderTransform><TranslateTransform x:Name="NetworkViewT" /></Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- notification transfert entrant -->
                        <RowDefinition Height="*" />     <!-- share panel / peer picker -->
                        <RowDefinition Height="Auto" />  <!-- saisie texte -->
                        <RowDefinition Height="Auto" />  <!-- statut d'envoi -->
                    </Grid.RowDefinitions>

                    <!-- ── Notification transfert entrant ── -->
                    <Border x:Name="IncomingPanel" Grid.Row="0"
                            Visibility="Collapsed"
                            Background="#1EFFFFFF"
                            CornerRadius="{StaticResource Radius2XL}"
                            BorderBrush="#30FFFFFF" BorderThickness="1"
                            Padding="10,8" Margin="0,0,0,6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Fill="#CCFFFFFF" Stretch="Uniform" Width="18" Height="18"
                                      Margin="0,0,10,0" VerticalAlignment="Center"
                                      Data="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14z" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="IncomingSender" Foreground="White" FontSize="{StaticResource FontBody}" FontWeight="SemiBold" />
                                    <TextBlock x:Name="IncomingFiles" Foreground="#BBFFFFFF" FontSize="{StaticResource FontCaption2}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,7,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource AcceptButton}" Click="OnAcceptTransfer">✓  Accepter</Button>
                                <Button Grid.Column="2" Style="{StaticResource DeclineButton}" Click="OnDeclineTransfer">✕  Refuser</Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── Zone principale (SharePanel ou PeerPickerPanel) ── -->
                    <Grid Grid.Row="1" MinHeight="110">

                        <!-- SHARE PANEL : Zone d'envoi LocalSend (pleine largeur) -->
                        <Grid x:Name="SharePanel">
                            <!-- Zone d'envoi LocalSend -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Zone fichiers (drop target) -->
                                <Border Grid.Row="0"
                                        Background="#0CFFFFFF" CornerRadius="{StaticResource Radius2XL}"
                                        BorderBrush="#1AFFFFFF" BorderThickness="1"
                                        AllowDrop="True"
                                        DragOver="OnSendZoneDragOver" Drop="OnSendZoneDrop">
                                    <Grid>
                                        <TextBlock x:Name="SendHint" Text="Glisser pour envoyer"
                                                   Foreground="#44FFFFFF" FontSize="{StaticResource FontTiny}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   TextAlignment="Center" TextWrapping="Wrap" MaxWidth="80" />
                                        <ScrollViewer x:Name="NetworkFilesScroll"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      VerticalAlignment="Center" Margin="4,0"
                                                      Visibility="Collapsed">
                                            <ItemsControl x:Name="NetworkFilesList">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="48" Margin="2,1" Padding="3,4"
                                                                CornerRadius="{StaticResource RadiusXL}"
                                                                Background="#16FFFFFF" Cursor="Hand" ToolTip="{Binding Path}">
                                                            <StackPanel>
                                                                <Grid Width="26" Height="26" HorizontalAlignment="Center">
                                                                    <Image Source="{Binding Icon}" Width="26" Height="26" />
                                                                    <Border Width="20" Height="20" Background="Transparent"
                                                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                            Margin="0,-7,-9,0" Cursor="Hand"
                                                                            Tag="{Binding}" MouseLeftButtonDown="OnNetworkFileRemove">
                                                                        <Border Width="13" Height="13" CornerRadius="6.5"
                                                                                Background="#DD1C1C1E" BorderBrush="#55FFFFFF" BorderThickness="1"
                                                                                IsHitTestVisible="False">
                                                                            <TextBlock Text="✕" Foreground="White" FontSize="{StaticResource FontMicro}"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Border>
                                                                    </Border>
                                                                </Grid>
                                                                <TextBlock Text="{Binding Name}" Foreground="#DDFFFFFF"
                                                                           FontSize="{StaticResource FontTiny}"
                                                                           TextTrimming="CharacterEllipsis" TextAlignment="Center"
                                                                           MaxWidth="42" Margin="0,2,0,0" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <!-- Barre d'action : T, image, flèche envoi -->
                                <Grid Grid.Row="1" Margin="0,4,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Style="{StaticResource MediaButton}" Width="26" Height="26"
                                                ToolTip="Écrire un message texte" Click="OnToggleTextInput">
                                            <TextBlock Text="T" Foreground="#CCFFFFFF"
                                                       FontSize="{StaticResource FontHeadline}" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                        <Button Style="{StaticResource MediaButton}" Width="26" Height="26"
                                                Margin="2,0,0,0" ToolTip="Coller image (presse-papier)" Click="OnPasteImage">
                                            <Path Fill="#CCFFFFFF" Stretch="Uniform" Width="14" Height="14"
                                                  Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z" />
                                        </Button>
                                    </StackPanel>
                                    <!-- Flèche → ouvre le sous-menu appareils -->
                                    <Button x:Name="SendArrowButton"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource MediaButton}" Width="32" Height="32"
                                            ToolTip="Choisir un appareil et envoyer"
                                            Click="OnShowPeerPicker"
                                            IsEnabled="False">
                                        <Path Fill="#CCFFFFFF" Stretch="Uniform" Width="15" Height="15"
                                              Data="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- PEER PICKER : sous-menu appareils (s'affiche sur la flèche) -->
                        <Grid x:Name="PeerPickerPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- En-tête : retour + titre -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Button HorizontalAlignment="Left"
                                        Style="{StaticResource MediaButton}" Width="26" Height="26"
                                        ToolTip="Retour" Click="OnHidePeerPicker">
                                    <Path Fill="#CCFFFFFF" Stretch="Uniform" Width="15" Height="15"
                                          Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                </Button>
                                <TextBlock Text="Envoyer à…"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#BBFFFFFF" FontSize="{StaticResource FontHeadline}" />
                            </Grid>

                            <!-- Liste des appareils -->
                            <Grid Grid.Row="1">
                                <TextBlock x:Name="PeerEmptyText"
                                           Text="Recherche d'appareils LocalSend sur le réseau…"
                                           Foreground="#8AFFFFFF" FontSize="{StaticResource FontCaption2}"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           MaxWidth="360" />
                                <ItemsControl x:Name="PeerList" Visibility="Collapsed">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,2" Padding="10,7" CornerRadius="{StaticResource RadiusXL}"
                                                    Background="#18FFFFFF" Cursor="Hand"
                                                    MouseLeftButtonDown="OnPeerClick">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Path Grid.Column="0" Fill="#CCFFFFFF"
                                                          Stretch="Uniform" Width="16" Height="16"
                                                          Margin="0,0,10,0" VerticalAlignment="Center"
                                                          IsHitTestVisible="False"
                                                          Data="{Binding DeviceIconPath}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Alias}"
                                                               Foreground="White" FontSize="{StaticResource FontHeadline}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               IsHitTestVisible="False" />
                                                    <Path Grid.Column="2" Fill="#99FFFFFF"
                                                          Stretch="None" VerticalAlignment="Center"
                                                          Margin="8,0,0,0" IsHitTestVisible="False"
                                                          Data="M8 5v14l11-7z" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Saisie texte (masquée par défaut, apparaît au clic de T) -->
                    <Border x:Name="TextInputPanel" Grid.Row="2"
                            Background="#20FFFFFF" CornerRadius="{StaticResource RadiusXL}" Padding="8,5"
                            Margin="0,4,0,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TextInputBox" Grid.Column="0"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="White" CaretBrush="White"
                                     SelectionBrush="#66FFFFFF" FontSize="{StaticResource FontBody}"
                                     VerticalAlignment="Center"
                                     AcceptsReturn="False"
                                     KeyDown="OnTextInputKeyDown" />
                            <Button Grid.Column="1" Style="{StaticResource MediaButton}"
                                    Width="26" Height="26" Margin="4,0,0,0"
                                    ToolTip="Ajouter à la liste d'envoi" Click="OnTextInputAdd">
                                <Path Fill="White" Stretch="None"
                                      Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Statut d'envoi -->
                    <TextBlock x:Name="SendStatus" Grid.Row="3" Text=""
                               Foreground="#AAD4EDFF" FontSize="{StaticResource FontCaption2}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,4,0,0" Visibility="Collapsed" />
                </Grid>

                <!-- ===== PAGE AUDIO : sortie + microphone ===== -->
                <Grid x:Name="AudioView" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RenderTransform><TranslateTransform x:Name="AudioViewT" /></Grid.RenderTransform>

                    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- ── Sortie audio ── -->
                            <TextBlock Text="Sortie audio"
                                       Foreground="#66FFFFFF" FontSize="{StaticResource FontCaption2}" FontWeight="SemiBold"
                                       Margin="2,0,0,8" />
                            <ItemsControl x:Name="AudioDeviceList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,2.5" Padding="12,9" CornerRadius="{StaticResource Radius2XL}"
                                                Cursor="Hand" MouseLeftButtonDown="OnAudioDeviceClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0DFFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter Property="Background" Value="#22FFFFFF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Fill="#CCFFFFFF" Stretch="Uniform"
                                                      Width="15" Height="15" VerticalAlignment="Center"
                                                      Margin="0,0,11,0" IsHitTestVisible="False"
                                                      Data="{Binding DeviceIconPath}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           Foreground="White" FontSize="{StaticResource FontBody}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                           IsHitTestVisible="False" />
                                                <Path Grid.Column="2" Fill="#FF34C759" Stretch="Uniform"
                                                      Width="13" Height="13" VerticalAlignment="Center"
                                                      Margin="9,0,0,0" IsHitTestVisible="False"
                                                      Visibility="{Binding CheckmarkVisibility}"
                                                      Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ── Microphone ── -->
                            <TextBlock Text="Microphone"
                                       Foreground="#66FFFFFF" FontSize="{StaticResource FontCaption2}" FontWeight="SemiBold"
                                       Margin="2,12,0,8" />
                            <ItemsControl x:Name="MicDeviceList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,2.5" Padding="12,9" CornerRadius="{StaticResource Radius2XL}"
                                                Cursor="Hand" MouseLeftButtonDown="OnAudioDeviceClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0DFFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter Property="Background" Value="#22FFFFFF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Fill="#CCFFFFFF" Stretch="Uniform"
                                                      Width="15" Height="15" VerticalAlignment="Center"
                                                      Margin="0,0,11,0" IsHitTestVisible="False"
                                                      Data="{Binding DeviceIconPath}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           Foreground="White" FontSize="{StaticResource FontBody}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                           IsHitTestVisible="False" />
                                                <Path Grid.Column="2" Fill="#FF34C759" Stretch="Uniform"
                                                      Width="13" Height="13" VerticalAlignment="Center"
                                                      Margin="9,0,0,0" IsHitTestVisible="False"
                                                      Visibility="{Binding CheckmarkVisibility}"
                                                      Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ===== PAGE CALENDRIER : vue complète (jour) ===== -->
                <Grid x:Name="CalendarView" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RenderTransform><TranslateTransform x:Name="CalendarViewT" /></Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- En-tête : mois + état connexion + bande de jours + bouton connect -->
                    <Grid Grid.Row="0" Margin="2,0,2,6">
                        <!-- Gauche : mois + statut -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <TextBlock x:Name="CalFullMonth" Text="—"
                                       Foreground="White" FontSize="{StaticResource FontTitle}" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="CalFullStatus" Text="Aucune source connectée"
                                       Foreground="#66FFFFFF" FontSize="{StaticResource FontCaption2}"
                                       VerticalAlignment="Center" Margin="10,2,0,0" />
                        </StackPanel>

                        <!-- Droite : bande de jours + bouton Google -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <StackPanel x:Name="CalFullDays" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button x:Name="CalConnectBtn"
                                    Style="{StaticResource MediaButton}"
                                    ToolTip="Connecter un calendrier iCal"
                                    Click="OnCalendarConnectClick">
                                <!-- Icône maillon de chaîne (lien iCal) -->
                                <Path Fill="#CCffffff" Stretch="Uniform" Width="14" Height="14"
                                      Data="M17 7h-4v2h4c1.65 0 3 1.35 3 3s-1.35 3-3 3h-4v2h4c2.76 0 5-2.24 5-5s-2.24-5-5-5zm-6 8H7c-1.65 0-3-1.35-3-3s1.35-3 3-3h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-2zm-3-4h8v2H8z" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Timeline 24 h pleine hauteur — inner refraction border (taste-skill §4 Liquid Glass) -->
                    <Border Grid.Row="1" Background="#0AFFFFFF" CornerRadius="{StaticResource Radius2XL}"
                            ClipToBounds="True" Margin="0,0,0,2"
                            BorderBrush="#16FFFFFF" BorderThickness="0,1,0,0">
                        <ScrollViewer x:Name="CalFullScroll"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Focusable="False">
                            <Canvas x:Name="CalFullTimeline" Width="600">
                                <Canvas.RenderTransform>
                                    <TranslateTransform x:Name="CalTimelineT" />
                                </Canvas.RenderTransform>
                            </Canvas>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===== MINI-MODE REPLIÉ : micro-pochette + égaliseur (visible notch fermée) ===== -->
            <!-- IsHitTestVisible piloté par code (RefreshMiniOpacity) selon HasSession + ExpansionProgress -->
            <Grid x:Name="MiniContent" Opacity="0" IsHitTestVisible="False" Margin="12,0,12,0"
                  Cursor="Hand" MouseLeftButtonDown="OnMiniContentClick"
                  ToolTip="Cliquer pour lecture / pause">
                <Border Width="24" Height="24" CornerRadius="{StaticResource RadiusM}"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Background="#22FFFFFF">
                    <Image Source="{Binding AlbumArt}" Stretch="UniformToFill">
                        <Image.Clip><RectangleGeometry Rect="0,0,24,24" RadiusX="6" RadiusY="6" /></Image.Clip>
                    </Image>
                </Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Width="3" Height="16" CornerRadius="1.5" Background="#E6FFFFFF"
                            VerticalAlignment="Bottom" Margin="1.5,0" RenderTransformOrigin="0.5,1">
                        <Border.RenderTransform><ScaleTransform x:Name="EqBar1Scale" ScaleY="0.30" /></Border.RenderTransform>
                    </Border>
                    <Border Width="3" Height="16" CornerRadius="1.5" Background="#E6FFFFFF"
                            VerticalAlignment="Bottom" Margin="1.5,0" RenderTransformOrigin="0.5,1">
                        <Border.RenderTransform><ScaleTransform x:Name="EqBar2Scale" ScaleY="0.55" /></Border.RenderTransform>
                    </Border>
                    <Border Width="3" Height="16" CornerRadius="1.5" Background="#E6FFFFFF"
                            VerticalAlignment="Bottom" Margin="1.5,0" RenderTransformOrigin="0.5,1">
                        <Border.RenderTransform><ScaleTransform x:Name="EqBar3Scale" ScaleY="0.40" /></Border.RenderTransform>
                    </Border>
                    <Border Width="3" Height="16" CornerRadius="1.5" Background="#E6FFFFFF"
                            VerticalAlignment="Bottom" Margin="1.5,0" RenderTransformOrigin="0.5,1">
                        <Border.RenderTransform><ScaleTransform x:Name="EqBar4Scale" ScaleY="0.60" /></Border.RenderTransform>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Keep-Awake mini indicator : icône café, visible notch repliée quand activé -->
            <Path x:Name="CoffeeMiniIndicator"
                  Opacity="0" IsHitTestVisible="False"
                  Fill="#E6FFFFFF" Stretch="Uniform" Width="13" Height="13"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  Margin="0,0,14,0"
                  Data="M20 3H4v10c0 2.21 1.79 4 4 4h6c2.21 0 4-1.79 4-4v-3h2c1.1 0 2-.89 2-2V5c0-1.11-.89-2-2-2zm0 5h-2V5h2v3zM4 19h16v2H4z" />

            <!-- Battery mini indicator : batterie compacte visible notch repliée (charge ou niveau critique) -->
            <Grid x:Name="BatteryMiniIndicator" Opacity="0" IsHitTestVisible="False"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  Width="19" Margin="0,0,14,0">
                <!-- Corps batterie -->
                <Border Width="16" Height="10" CornerRadius="2.5"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        BorderThickness="1.3">
                    <Border.BorderBrush><SolidColorBrush Color="#E6FFFFFF" /></Border.BorderBrush>
                </Border>
                <!-- Nub -->
                <Border Width="2.5" Height="5" CornerRadius="1.2" Background="#E6FFFFFF"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="16.5,0,0,0" />
                <!-- Fill animé (ScaleX 0→1) -->
                <Border x:Name="BatteryMiniFillBar" Height="6" Width="11" CornerRadius="1.5"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="2.5,0,0,0" RenderTransformOrigin="0,0.5">
                    <Border.Background>
                        <SolidColorBrush x:Name="BatteryMiniColor" Color="#FF30D158" />
                    </Border.Background>
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="BatteryMiniFillScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                </Border>
                <!-- Bolt overlay quand en charge -->
                <Path x:Name="BatteryMiniBolt" Fill="#1C1C1E" Stretch="Uniform"
                      Width="5" Height="8" Visibility="Collapsed"
                      HorizontalAlignment="Left" VerticalAlignment="Center"
                      Margin="5.5,0,0,0"
                      Data="M6,0 L0,7 H4 L3,14 L10,5 H5 Z" />
            </Grid>

            <!-- ===== VOLUME HUD : overlay touches média volume ===== -->
            <!-- Opacity/transforms pilotés par code. Background noir pour masquer MiniContent dessous. -->
            <Grid x:Name="VolumeHudPanel" Opacity="0" IsHitTestVisible="False"
                  Margin="12,0,12,0" Background="#FF000000">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="VolumeHudSlideT" />
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Icône haut-parleur — son -->
                <Path x:Name="VolumeIconSound" Grid.Column="0"
                      Fill="White" Stretch="Uniform" Width="16" Height="16"
                      VerticalAlignment="Center" Margin="0,0,9,0"
                      RenderTransformOrigin="0.5,0.5"
                      Data="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM18.5 12c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z">
                    <Path.RenderTransform>
                        <ScaleTransform x:Name="VolumeIconSoundScale" ScaleX="1" ScaleY="1" />
                    </Path.RenderTransform>
                </Path>

                <!-- Icône haut-parleur — muet (remplace le précédent) -->
                <Path x:Name="VolumeIconMuted" Grid.Column="0"
                      Fill="#FFFF3B30" Stretch="Uniform" Width="16" Height="16"
                      VerticalAlignment="Center" Margin="0,0,9,0" Visibility="Collapsed"
                      RenderTransformOrigin="0.5,0.5"
                      Data="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z">
                    <Path.RenderTransform>
                        <ScaleTransform x:Name="VolumeIconMutedScale" ScaleX="1" ScaleY="1" />
                    </Path.RenderTransform>
                </Path>

                <!-- Barre de volume : remplissage piloté par ScaleX (0..1), origine à gauche -->
                <Grid x:Name="VolumeBarContainer" Grid.Column="1" Height="4"
                      VerticalAlignment="Center" Margin="0,0,10,0" ClipToBounds="True">
                    <Border Background="#33FFFFFF" CornerRadius="2" />
                    <Border x:Name="VolumeBarFill"
                            Background="White" CornerRadius="2"
                            HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="VolumeBarScale" ScaleX="0" ScaleY="1" />
                        </Border.RenderTransform>
                    </Border>
                </Grid>

                <!-- Pourcentage -->
                <TextBlock x:Name="VolumePercentText" Grid.Column="2"
                           Text="—%" Foreground="White" FontSize="{StaticResource FontCaption}" FontWeight="SemiBold"
                           VerticalAlignment="Center" MinWidth="34" TextAlignment="Right" />
            </Grid>

            <!-- ===== BATTERY HUD : live activity branchement / batterie faible ===== -->
            <Grid x:Name="BatteryHudPanel" Opacity="0" IsHitTestVisible="False"
                  Margin="12,0,12,0" Background="#FF000000">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="BatteryHudSlideT" />
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Icône batterie compacte avec fill coloré -->
                <Grid Grid.Column="0" Width="23" Height="14" VerticalAlignment="Center"
                      Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="BatteryHudIconScale" ScaleX="1" ScaleY="1" />
                    </Grid.RenderTransform>
                    <Border Width="20" Height="12" CornerRadius="3"
                            BorderBrush="White" BorderThickness="1.3"
                            HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <Border Width="2.5" Height="5.5" CornerRadius="1.2" Background="White"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Margin="20.5,0,0,0" />
                    <!-- Fill : ScaleX 0→1, couleur animée -->
                    <Border x:Name="BatteryHudFillBar" Height="7.5" Width="15" CornerRadius="1.5"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Margin="2.5,0,0,0" RenderTransformOrigin="0,0.5">
                        <Border.Background>
                            <SolidColorBrush x:Name="BatteryHudFillColor" Color="#FF30D158" />
                        </Border.Background>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BatteryHudFillScale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                    </Border>
                    <!-- Bolt overlay quand en charge -->
                    <Path x:Name="BatteryHudBolt" Fill="#1C1C1E" Stretch="Uniform"
                          Width="7" Height="11" Visibility="Collapsed"
                          HorizontalAlignment="Left" VerticalAlignment="Center"
                          Margin="6.5,0,0,0"
                          Data="M6,0 L0,7 H4 L3,14 L10,5 H5 Z" />
                </Grid>

                <!-- Barre de niveau -->
                <Grid Grid.Column="1" Height="4" VerticalAlignment="Center"
                      Margin="0,0,10,0" ClipToBounds="True">
                    <Border Background="#33FFFFFF" CornerRadius="2" />
                    <Border CornerRadius="2" HorizontalAlignment="Stretch"
                            RenderTransformOrigin="0,0.5">
                        <Border.Background>
                            <SolidColorBrush x:Name="BatteryHudBarColor" Color="#FF30D158" />
                        </Border.Background>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BatteryHudBarScale" ScaleX="0" ScaleY="1" />
                        </Border.RenderTransform>
                    </Border>
                </Grid>

                <!-- Pourcentage + état -->
                <TextBlock x:Name="BatteryHudText" Grid.Column="2"
                           Text="—%" Foreground="White" FontSize="{StaticResource FontCaption}" FontWeight="SemiBold"
                           VerticalAlignment="Center" MinWidth="34" TextAlignment="Right" />
            </Grid>

            <!-- ===== OVERLAY DRAG & DROP : double cible Garder / Envoyer ===== -->
            <!-- Background dans un Border enfant arrondi pour éviter les coins carrés
                 (ClipToBounds coupe en rectangle, pas selon CornerRadius du parent) -->
            <Grid x:Name="DragOverlay" Opacity="0" IsHitTestVisible="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="2" Background="#B3000000"
                        CornerRadius="0,0,32,32" IsHitTestVisible="False" />

                <Border x:Name="DropKeep" Grid.Column="0" Margin="10,10,5,12"
                        Background="#14FFFFFF" CornerRadius="{StaticResource Radius3XL}"
                        BorderBrush="#33FFFFFF" BorderThickness="1.4"
                        AllowDrop="True" RenderTransformOrigin="0.5,0.5"
                        DragEnter="OnDropKeepEnter" DragOver="OnDropKeepEnter"
                        DragLeave="OnDropZoneLeave" Drop="OnDropKeep">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="DropKeepScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                        <Path Fill="#CCFFFFFF" Stretch="Uniform" Width="26" Height="26"
                              HorizontalAlignment="Center"
                              Data="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 12h-4c0 1.66-1.35 3-3 3s-3-1.34-3-3H4.99V5H19v10z" />
                        <TextBlock Text="Ajouter" Foreground="White" FontSize="{StaticResource FontHeadline}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,6,0,0" />
                        <TextBlock Text="à l'envoi" Foreground="#99FFFFFF" FontSize="{StaticResource FontCaption2}"
                                   HorizontalAlignment="Center" Margin="0,1,0,0" />
                    </StackPanel>
                </Border>

                <Border x:Name="DropSend" Grid.Column="1" Margin="5,10,10,12"
                        Background="#14FFFFFF" CornerRadius="{StaticResource Radius3XL}"
                        BorderBrush="#33FFFFFF" BorderThickness="1.4"
                        AllowDrop="True" RenderTransformOrigin="0.5,0.5"
                        DragEnter="OnDropSendEnter" DragOver="OnDropSendEnter"
                        DragLeave="OnDropZoneLeave" Drop="OnDropSend">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="DropSendScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                        <Path Fill="#CCFFFFFF" Stretch="Uniform" Width="26" Height="26"
                              HorizontalAlignment="Center"
                              Data="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                        <TextBlock Text="Envoyer" Foreground="White" FontSize="{StaticResource FontHeadline}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,6,0,0" />
                        <TextBlock Text="vers un appareil" Foreground="#99FFFFFF" FontSize="{StaticResource FontCaption2}"
                                   HorizontalAlignment="Center" Margin="0,1,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
          </Grid>
        </Border>
    </Grid>
</Window>
