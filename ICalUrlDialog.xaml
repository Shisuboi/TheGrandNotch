<Window x:Class="TheGrandNotch.ICalUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connecter un calendrier"
        Width="500" Height="220"
        MinWidth="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF1C1C1E"
        Foreground="White"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="18,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="Adresse iCal du calendrier"
                   FontSize="15" FontWeight="SemiBold" Foreground="White" />

        <!-- Instructions -->
        <TextBlock Grid.Row="2" TextWrapping="Wrap"
                   FontSize="12" Foreground="#99FFFFFF" LineHeight="18">
            Google Calendar → Paramètres → votre calendrier →
            "Adresse secrète au format iCal" → copier l'URL
        </TextBlock>

        <!-- Champ URL -->
        <Border Grid.Row="4" Background="#2AFFFFFF" CornerRadius="8"
                BorderBrush="#30FFFFFF" BorderThickness="1">
            <TextBox x:Name="UrlBox"
                     Background="Transparent" BorderThickness="0"
                     Foreground="White" CaretBrush="White"
                     SelectionBrush="#66FFFFFF"
                     FontSize="12" Padding="12,8"
                     VerticalAlignment="Center"
                     KeyDown="OnUrlBoxKeyDown" />
        </Border>

        <!-- Boutons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="DisconnectBtn"
                    Style="{StaticResource DarkButton}"
                    Background="#28FFFFFF"
                    Content="Déconnecter"
                    Visibility="Collapsed"
                    Margin="0,0,8,0"
                    Click="OnDisconnect" />
            <Button Style="{StaticResource DarkButton}"
                    Background="#2AFFFFFF"
                    Content="Annuler"
                    Margin="0,0,8,0"
                    Click="OnCancel" />
            <Button Style="{StaticResource DarkButton}"
                    Background="#FF0A84FF"
                    Content="Connecter"
                    Click="OnConfirm" />
        </StackPanel>
    </Grid>
</Window>
